{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "MassTransit": "Information",
        "System": "Warning"
      }
    }
  },
  // ── RabbitMQ ──────────────────────────────────────────────────────────────
  // Store credentials in Secret Manager (dev) or Azure Key Vault (prod).
  //   dotnet user-secrets set "RabbitMQ:Password" "<password>"
  // RetryCount / RetryIntervalSeconds: consumer-level exponential back-off.
  //   Effective waits (defaults): 5s -> 25s -> 125s.
  // PrefetchCount: concurrent unacknowledged messages per consumer instance.
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "enterpriselink",
    "Username": "eluser",
    "Password": "elpassword",
    "RetryCount": 3,
    "RetryIntervalSeconds": 5,
    "PrefetchCount": 16
  },
  // ── File Storage ──────────────────────────────────────────────────────────
  // BasePath must match the Ingestion service's FileStorage:Local:BasePath so
  // both services resolve to the same physical directory.
  // In Docker Compose this is a shared named volume; bare metal uses a UNC/NFS path.
  "FileStorage": {
    "Local": {
      "BasePath": "uploads"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  }
}
