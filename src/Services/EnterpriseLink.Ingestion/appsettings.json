{
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  // ── Entra ID ──────────────────────────────────────────────────────────────
  // Store real values in .NET Secret Manager (dev) or Azure Key Vault (prod).
  //   dotnet user-secrets set "AzureAd:TenantId" "<your-tenant-id>"
  //   dotnet user-secrets set "AzureAd:ClientId" "<your-client-id>"
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "__REPLACE_WITH_ENTRA_TENANT_ID__",
    "ClientId": "__REPLACE_WITH_ENTRA_CLIENT_ID__",
    "Audience": "api://__REPLACE_WITH_ENTRA_CLIENT_ID__"
  },
  // ── Ingestion Limits ──────────────────────────────────────────────────────
  // MaxFileSizeBytes: enforced at both Kestrel (connection) and validator layers.
  // MemoryBufferThresholdBytes: files above this are spooled to disk instead of RAM.
  "Ingestion": {
    "MaxFileSizeBytes": 524288000,
    "MemoryBufferThresholdBytes": 1048576
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "enterpriselink",
    "Username": "eluser",
    "Password": "elpassword"
  }
}
