{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Integration": {
    "StorageRoot": "C:\\temp\\el-integration-files"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "VirtualHost": "enterpriselink",
    "Username": "eluser",
    "Password": "elpassword",
    "RetryCount": 3,
    "RetryIntervalSeconds": 5
  },
  "SoapAdapters": [
    {
      "Name": "LegacyERP",
      "TenantId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
      "WsdlUrl": "http://localhost:9999/TransactionService?wsdl",
      "EndpointUrl": "http://localhost:9999/TransactionService",
      "OperationName": "GetTransactions",
      "SoapAction": "http://localhost:9999/GetTransactions",
      "SoapNamespace": "http://example.com/transactions/",
      "PollingIntervalSeconds": 300,
      "Enabled": false,
      "SourceSystem": "LegacyERP-SOAP",
      "FieldMappings": {
        "TransactionId": "ExternalReferenceId",
        "Amount": "Amount",
        "Description": "Description"
      }
    }
  ],
  "RestAdapters": [
    {
      "Name": "SalesforceTransactions",
      "TenantId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
      "BaseUrl": "https://api.example.com/transactions",
      "Method": "GET",
      "AuthScheme": "Bearer",
      "AuthToken": "__SET_IN_USER_SECRETS__",
      "ResponseArrayPath": "records",
      "PollingIntervalSeconds": 300,
      "Enabled": false,
      "SourceSystem": "SalesforceREST",
      "FieldMappings": {
        "Id": "ExternalReferenceId",
        "Amount__c": "Amount",
        "Description__c": "Description"
      }
    }
  ],
  "SftpConnectors": [
    {
      "Name": "LegacyFileDrop",
      "TenantId": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
      "Host": "sftp.example.com",
      "Port": 22,
      "Username": "sftpuser",
      "Password": "__SET_IN_USER_SECRETS__",
      "RemotePath": "/uploads/transactions/",
      "FilePattern": "*.csv",
      "ArchivePath": "/uploads/processed/",
      "PollingIntervalSeconds": 60,
      "Enabled": false,
      "SourceSystem": "LegacySFTP"
    }
  ]
}
