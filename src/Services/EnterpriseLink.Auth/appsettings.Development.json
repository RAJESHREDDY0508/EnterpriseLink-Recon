{
  /*
   * Development overrides for appsettings.json.
   *
   * Real Entra ID values must be provided via .NET User Secrets for local dev:
   *   dotnet user-secrets set "AzureAd:TenantId" "your-entra-tenant-id"
   *   dotnet user-secrets set "AzureAd:ClientId"  "your-app-client-id"
   *
   * For integration tests without a live Entra ID, use the test host with a
   * mocked JWT and bypass AddMicrosoftIdentityWebApi in the test WebApplicationFactory.
   *
   * TenantMappings below use deterministic dev GUIDs that match the test fixtures.
   */
  "AzureAd": {
    "TenantId": "common",
    "ClientId": "__SET_VIA_USER_SECRETS__",
    "Audience": "api://__SET_VIA_USER_SECRETS__"
  },

  "TenantMappings": {
    "11111111-1111-1111-1111-111111111111": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
    "22222222-2222-2222-2222-222222222222": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.Identity": "Information",
        "System": "Warning"
      }
    }
  }
}
