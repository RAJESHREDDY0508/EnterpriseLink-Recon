        }
      },
      "ingestion-cluster": {
        "Destinations": {
          "ingestion-destination": { "Address": "http://localhost:5240" }
        }
      },
      "dashboard-cluster": {
        "Destinations": {
          "dashboard-destination": { "Address": "http://localhost:5267" }
        }
      },
      "integration-cluster": {
        "Destinations": {
          "integration-destination": { "Address": "http://localhost:5300" }
        }
      }
    }
  }
}
