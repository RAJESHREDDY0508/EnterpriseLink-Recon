{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "GlobalPermitLimit": 1000,
    "GlobalWindowSeconds": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/auth" },
          { "X-Forwarded": "Set" }
        ]
      },
      "tenant-route": {
        "ClusterId": "tenant-cluster",
        "Match": { "Path": "/api/tenant/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/tenant" },
          { "X-Forwarded": "Set" }
        ]
      },
      "ingestion-route": {
        "ClusterId": "ingestion-cluster",
        "Match": { "Path": "/api/ingestion/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/ingestion" },
          { "X-Forwarded": "Set" }
        ]
      },
      "recon-route": {
        "ClusterId": "dashboard-cluster",
        "Match": { "Path": "/api/recon/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/recon" },
          { "X-Forwarded": "Set" }
        ]
      },
      "integration-route": {
        "ClusterId": "integration-cluster",
        "Match": { "Path": "/api/integration/{**catch-all}" },
        "Transforms": [
          { "PathRemovePrefix": "/api/integration" },
          { "X-Forwarded": "Set" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": { "Address": "http://auth-service:8080" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "tenant-cluster": {
        "Destinations": {
          "tenant-destination": { "Address": "http://tenant-service:8080" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "ingestion-cluster": {
        "Destinations": {
          "ingestion-destination": { "Address": "http://ingestion-service:8080" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "dashboard-cluster": {
        "Destinations": {
          "dashboard-destination": { "Address": "http://dashboard-service:8080" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      },
      "integration-cluster": {
        "Destinations": {
          "integration-destination": { "Address": "http://integration-service:8080" }
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/health"
          }
        }
      }
    }
  }
}
